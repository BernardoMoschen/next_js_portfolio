---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
  <main class="not-found">
    <div class="not-found-inner">
      <h1 class="error-code gradient-text">404</h1>

      <div class="terminal glass">
        <div class="terminal-header">
          <span class="terminal-dot terminal-dot--red"></span>
          <span class="terminal-dot terminal-dot--yellow"></span>
          <span class="terminal-dot terminal-dot--green"></span>
          <span class="terminal-title mono">bash — 80x24</span>
        </div>
        <div class="terminal-body mono">
          <p class="terminal-line">$ find / -name "this-page"</p>
          <p class="terminal-line terminal-output">&gt; searching...</p>
          <p class="terminal-line terminal-output terminal-error">&gt; ERROR: page not found</p>
          <p class="terminal-line terminal-output">&gt;</p>
          <p class="terminal-line terminal-output">&gt; suggested commands:</p>
          <p class="terminal-line terminal-output">
            &gt;&nbsp;&nbsp;
            <a href="/#hero" class="terminal-link">cd /home</a>
            <span class="terminal-comment">&mdash; go back to start</span>
          </p>
          <p class="terminal-line terminal-output">
            &gt;&nbsp;&nbsp;
            <a href="/#projects" class="terminal-link">ls /projects</a>
            <span class="terminal-comment">&mdash; browse my work</span>
          </p>
          <p class="terminal-line terminal-output">
            &gt;&nbsp;&nbsp;
            <a href="/#contact" class="terminal-link">cat /contact</a>
            <span class="terminal-comment">&mdash; get in touch</span>
          </p>
          <p class="terminal-line">$ <span class="cursor">_</span></p>
        </div>
      </div>

      <a href="/" class="btn btn-primary go-home-btn">Go Home</a>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .not-found-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    max-width: 600px;
    width: 100%;
    animation: fadeInUp 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) both;
  }

  .error-code {
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .terminal {
    width: 100%;
    overflow: hidden;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot--red { background: var(--color-error); }
  .terminal-dot--yellow { background: var(--color-warning); }
  .terminal-dot--green { background: var(--color-success); }

  .terminal-title {
    margin-left: auto;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .terminal-body {
    padding: 20px;
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .terminal-line {
    color: var(--color-text);
    white-space: pre;
  }

  .terminal-output {
    color: var(--color-text-secondary);
  }

  .terminal-error {
    color: var(--color-error);
    font-weight: 700;
  }

  .terminal-link {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s ease;
    border-bottom: 1px solid transparent;
  }

  .terminal-link:hover {
    color: var(--color-primary-light);
    border-bottom-color: var(--color-primary);
  }

  .terminal-comment {
    color: var(--color-text-muted);
    margin-left: 8px;
  }

  .cursor {
    animation: blink 1s step-end infinite;
    color: var(--color-primary);
    font-weight: 700;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .go-home-btn {
    margin-top: 8px;
  }

  @media (max-width: 480px) {
    .terminal-body {
      font-size: 0.75rem;
      padding: 16px;
    }
  }
</style>
